# ============================================================================
# Nursery Management System — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.
# ============================================================================

# ── Required ────────────────────────────────────────────────────────────────
# Secret used to sign login sessions. Use a long random string.
# A packaged (production) build REFUSES TO START if this is missing.
JWT_SECRET=change_me_to_a_long_random_string

# ── Optional: sensitive / deployment-specific ───────────────────────────────
# MongoDB connection URI for cloud sync. Falls back to the value saved in the
# app's settings if omitted.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nursery_db?retryWrites=true&w=majority

# Initial admin account — used ONLY when seeding a fresh (empty) database.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# Year assigned to imported payments/salaries (the workbook's monthly sheets
# carry no year). Defaults to the current calendar year if omitted.
IMPORT_DEFAULT_YEAR=2025

# ── Optional: non-sensitive seed overrides (first-run only) ─────────────────
# Uncomment any line to override the built-in default when seeding a new DB.
# Pricing (EGP)
# SEED_NURSERY_MONTHLY=2500
# SEED_NURSERY_DAILY=150
# SEED_NURSERY_HOURLY=30
# SEED_HOSTING_MONTHLY=3000
# SEED_HOSTING_DAILY=200
# SEED_HOSTING_HOURLY=40
# SEED_SESSION_HOURLY=100
# SEED_SESSION_DAILY=400
# Targets & capacity
# SEED_TARGET_PROFIT_PCT=0.20
# SEED_MAX_CAPACITY=50
# SEED_WORK_DAYS=22
# SEED_WORK_HOURS=8
# Branding
# SEED_BRAND_APP_NAME=أكاديمية زين الدين
# SEED_BRAND_ORG_NAME=مركز زين الدين للتوحد ونمو الطفل
# SEED_BRAND_PRIMARY_COLOR=#0f766e
# SEED_BRAND_ACCENT_COLOR=#f59e0b
# SEED_BRAND_PHONE=+20 123 456 7890
# SEED_BRAND_EMAIL=info@zaineldeen.com
